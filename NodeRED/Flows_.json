        "type": "function",
        "z": "c7f044d6e7272d96",
        "name": "function 3",
        "func": "let d = msg.payload;\n\nlet lat = 15.75819;\nlet lon = 78.04025;\nlet mapLink = `https://www.openstreetmap.org/?mlat=${lat}&mlon=${lon}#map=16/${lat}/${lon}`;\n\nmsg.topic = \"🚗 Smart Parking Alert\";\n\nmsg.payload =\n    \"Smart Parking Status Update\\n\\n\" +\n    \"Parking Status      : \" + d[\"parking/status\"] + \"\\n\" +\n    \"Total Slots         : 5\\n\" +\n    \"Filled Slots        : \" + d[\"parking/slots/filled\"] + \"\\n\" +\n    \"Available Slots     : \" + d[\"parking/slots/available\"] + \"\\n\\n\" +\n    \"Temperature         : \" + d[\"parking/environment/temperature\"] + \" °C\\n\" +\n    \"Humidity            : \" + d[\"parking/environment/humidity\"] + \" %\\n\\n\" +\n    \"Slot Map            : \" + d[\"parking/slot/map\"] + \"\\n\\n\" +\n    \"Parking Location Map:\\n\" +\n    mapLink + \"\\n\\n\" +\n    \"— Smart Parking System\";\n\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
