    {
        "id": "c588fadb4179ee2b",
        "type": "function",
        "z": "c7f044d6e7272d96",
        "name": "slot_box",
        "func": "const TOTAL_SLOTS = 5;\n\n// payload is now just a number\nlet filled = Number(msg.payload);\n\nif (isNaN(filled)) filled = 0;\nif (filled < 0) filled = 0;\nif (filled > TOTAL_SLOTS) filled = TOTAL_SLOTS;\n\nlet slots = [];\nfor (let i = 0; i < TOTAL_SLOTS; i++) {\n    slots.push(i < filled);\n}\n\nmsg.payload = slots;\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1080,
        "y": 100,
        "wires": [
            [
                "ad0bb46bc1ae55a5"
            ]
        ]
    },
