    {
        "id": "fb9a6e9d700ac2fa",
        "type": "ui-template",
        "z": "c7f044d6e7272d96",
        "group": "3b9c647e0fba08c3",
        "page": "",
        "ui": "",
        "name": "slot_mapper",
        "order": 1,
        "width": 0,
        "height": 0,
        "head": "",
        "format": "<template>\n  <div style=\"display:flex; gap:15px; justify-content:center;\">\n    <div\n      v-for=\"(slot, index) in slots\"\n      :key=\"index\"\n      class=\"slot\"\n      :class=\"slot === 'CAR' ? 'occupied' : 'free'\"\n    >\n      {{ slot }}\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      slots: []\n    }\n  },\n  mounted() {\n    this.parsePayload(this.msg)\n  },\n  watch: {\n    msg(newMsg) {\n      this.parsePayload(newMsg)\n    }\n  },\n  methods: {\n    parsePayload(msg) {\n      if (!msg || !msg.payload) return;\n\n      // Convert payload to string\n      let text = msg.payload.toString();\n\n      // Extract values between []\n      let matches = text.match(/\\[(.*?)\\]/g);\n      if (!matches) return;\n\n      // Clean values: [\"CAR\", \"FREE\", ...]\n      this.slots = matches.map(s =>\n        s.replace(\"[\", \"\").replace(\"]\", \"\")\n      );\n    }\n  }\n}\n</script>\n\n<style>\n.slot {\n  width: 80px;\n  height: 80px;\n  border-radius: 10px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: white;\n  font-weight: bold;\n  border: 2px solid #333;\n}\n\n.free {\n  background-color: green;\n}\n\n.occupied {\n  background-color: red;\n}\n</style>\n",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 670,
        "y": 80,
        "wires": [
            []
        ]
    },
